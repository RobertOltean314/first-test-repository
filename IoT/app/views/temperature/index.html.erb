<% content_for :title, "Temperature Readings" %>

<style>
  body { font-family: sans-serif; margin: 2rem; background: #f5f5f5; color: #333; }
  h1 { font-size: 1.5rem; margin-bottom: 1.5rem; }
  .chart-container { background: #fff; border-radius: 6px; box-shadow: 0 1px 4px rgba(0,0,0,0.1); padding: 1.5rem; margin-bottom: 2rem; }
  table { width: 100%; border-collapse: collapse; background: #fff; border-radius: 6px; overflow: hidden; box-shadow: 0 1px 4px rgba(0,0,0,0.1); }
  th { background: #2563eb; color: #fff; padding: 0.75rem 1rem; text-align: left; font-weight: 600; }
  td { padding: 0.65rem 1rem; border-bottom: 1px solid #e5e7eb; }
  tr:last-child td { border-bottom: none; }
  tr:nth-child(even) td { background: #f9fafb; }
  .empty { text-align: center; padding: 2rem; color: #6b7280; }
</style>

<h1>Temperature Readings</h1>

<% if @readings.any? %>
  <div class="chart-container">
    <canvas id="tempChart"></canvas>
  </div>

  <table>
    <thead>
      <tr>
        <th>#</th>
        <th>Temperature (°C)</th>
        <th>Read At</th>
      </tr>
    </thead>
    <tbody>
      <% @readings.each_with_index do |r, i| %>
        <tr>
          <td><%= i + 1 %></td>
          <td><%= r.temperature %></td>
          <td><%= r.read_at.strftime("%Y-%m-%d %H:%M:%S UTC") %></td>
        </tr>
      <% end %>
    </tbody>
  </table>

  <script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.0/dist/chart.umd.min.js"></script>
  <script src="https://cdn.jsdelivr.net/npm/chartjs-adapter-date-fns@3.0.0/dist/chartjs-adapter-date-fns.bundle.min.js"></script>
  <script>
    const labels = <%= raw @readings.reverse.map { |r| r.read_at.iso8601 }.to_json %>;
    const values = <%= raw @readings.reverse.map { |r| r.temperature }.to_json %>;

    new Chart(document.getElementById("tempChart"), {
      type: "line",
      data: {
        labels: labels,
        datasets: [{
          label: "Temperature (°C)",
          data: values,
          borderColor: "#2563eb",
          backgroundColor: "rgba(37,99,235,0.1)",
          tension: 0.3,
          pointRadius: 3,
          fill: true
        }]
      },
      options: {
        scales: {
          x: {
            type: "time",
            time: { tooltipFormat: "yyyy-MM-dd HH:mm:ss" },
            title: { display: true, text: "Time" }
          },
          y: {
            title: { display: true, text: "°C" }
          }
        },
        plugins: {
          legend: { display: false }
        }
      }
    });
  </script>
<% else %>
  <p class="empty">No readings yet.</p>
<% end %>
