<% content_for :title, "Temperature Readings" %>

<style>
  body { font-family: sans-serif; margin: 2rem; background: #f5f5f5; color: #333; }
  h1 { font-size: 1.5rem; margin-bottom: 1.5rem; }
  table { width: 100%; border-collapse: collapse; background: #fff; border-radius: 6px; overflow: hidden; box-shadow: 0 1px 4px rgba(0,0,0,0.1); }
  th { background: #2563eb; color: #fff; padding: 0.75rem 1rem; text-align: left; font-weight: 600; }
  td { padding: 0.65rem 1rem; border-bottom: 1px solid #e5e7eb; }
  tr:last-child td { border-bottom: none; }
  tr:nth-child(even) td { background: #f9fafb; }
  .empty { text-align: center; padding: 2rem; color: #6b7280; }
</style>

<h1>Temperature Readings</h1>

<% if @readings.any? %>
  <table>
    <thead>
      <tr>
        <th>#</th>
        <th>Temperature (°C)</th>
        <th>Read At</th>
      </tr>
    </thead>
    <tbody>
      <% @readings.each_with_index do |r, i| %>
        <tr>
          <td><%= i + 1 %></td>
          <td><%= r.temperature %></td>
          <td><%= r.read_at.strftime("%Y-%m-%d %H:%M:%S UTC") %></td>
        </tr>
      <% end %>
    </tbody>
  </table>
<% else %>
  <p class="empty">No readings yet.</p>
<% end %>
